#!/usr/bin/env bash
# gpu-handoff - libvirt qemu hook. Managed by privatestack-ansible
# (roles/gpu_handoff). Do not hand-edit: the next run overwrites this file.
#
# Protocol: between reboots the GPU only moves DOWN the trust ladder.
#   clean(3) -> dev(2) -> dirty(1) -> lab(0)
# Same level restarts freely; any step UP is refused until a reboot wipes
# /run. Domains not listed in the rotation are not GPU domains: they pass
# through untouched. Anything ambiguous about the protocol's own config or
# state REFUSES - fail closed.
set -u

ROTATION_FILE="${GPU_HANDOFF_ROTATION:-/etc/gpu-handoff/rotation}"
STATE_DIR="${GPU_HANDOFF_STATE_DIR:-/run/gpu-handoff}"
STATE_FILE="${STATE_DIR}/trust"

domain="${1:-}"
phase="${2:-}"

# Only the prepare phase guards; every other phase passes instantly.
[[ "${phase}" == "prepare" ]] || exit 0

if [[ -z "${domain}" ]]; then
    echo "gpu-handoff: missing domain argument: refusing (fail closed)" >&2
    exit 1
fi

# The rotation list is the protocol's own config. Unreadable means we
# cannot even decide membership: fail closed for everyone.
if [[ ! -r "${ROTATION_FILE}" ]]; then
    echo "gpu-handoff: rotation ${ROTATION_FILE} missing or unreadable: refusing (fail closed)" >&2
    exit 1
fi

trust=""
entries=0
while read -r name level _; do
    if [[ -z "${name}" || "${name}" == \#* ]]; then
        continue
    fi
    if [[ ! "${level}" =~ ^[0-9]+$ ]]; then
        echo "gpu-handoff: corrupt rotation line ('${name} ${level}'): refusing (fail closed)" >&2
        exit 1
    fi
    entries=$((entries + 1))
    if [[ "${name}" == "${domain}" ]]; then
        trust="${level}"
    fi
done < "${ROTATION_FILE}"

# An empty rotation is not "handoff disabled" - it is a broken config.
# Disabling the handoff means removing the hook, deliberately.
if (( entries == 0 )); then
    echo "gpu-handoff: rotation ${ROTATION_FILE} has no valid entries: refusing (fail closed)" >&2
    exit 1
fi

# Not in rotation: not a GPU domain. Pass through, never touch state.
if [[ -z "${trust}" ]]; then
    exit 0
fi

if ! mkdir -p "${STATE_DIR}"; then
    echo "gpu-handoff: cannot create ${STATE_DIR}: refusing (fail closed)" >&2
    exit 1
fi

if [[ -e "${STATE_FILE}" ]]; then
    current="$(cat "${STATE_FILE}" 2>/dev/null || true)"
    if [[ ! "${current}" =~ ^[0-9]+$ ]]; then
        echo "gpu-handoff: corrupt state '${current}': refusing (fail closed) - a reboot resets it" >&2
        exit 1
    fi
    if (( trust > current )); then
        echo "gpu-handoff: REFUSING ${domain} (trust ${trust}): GPU held at trust ${current}; trust only rises through a reboot" >&2
        exit 1
    fi
fi

printf '%s\n' "${trust}" > "${STATE_FILE}"
exit 0
