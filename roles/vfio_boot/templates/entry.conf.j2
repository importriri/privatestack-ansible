# systemd-boot profile - {{ item.title }}
# Managed by privatestack-ansible (roles/vfio_boot). Do not hand-edit:
# the next run overwrites this file - change the role instead.
#
# FORMAT: strict "key value" lines. There is NO backslash continuation in
# the Boot Loader Specification: a line starting with an unknown key is
# silently dropped and the machine STILL BOOTS, missing half its
# parameters. One options line per logical group; the loader concatenates
# them in order.

title   {{ item.title }}
linux   /vmlinuz-{{ kernel_name }}
initrd  /initramfs-{{ kernel_name }}.img
options rd.luks.name={{ vfio_boot_luks_uuid }}={{ luks_mapper_name }} root=/dev/mapper/{{ luks_mapper_name }} rootfstype=btrfs rootflags=subvol={{ root_subvol }} rw
options zswap.enabled=0
{% for group in item.option_groups %}
options {{ group }}
{% endfor %}
